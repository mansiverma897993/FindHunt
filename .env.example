# --- Hela deploy (Hardhat) — put secrets in .env.local only ---
DEPLOYER_PRIVATE_KEY=
HELA_TESTNET_RPC_URL=https://testnet-rpc.helachain.com

# WalletConnect / Reown — https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional custom Hela RPC for the browser
NEXT_PUBLIC_HELA_RPC_URL=https://testnet-rpc.helachain.com

# After deploy (see contracts/ and README)
NEXT_PUBLIC_TREASURER_VAULT=
NEXT_PUBLIC_BUDGET_CONTROLLER=
NEXT_PUBLIC_SUBSCRIPTION_MANAGER=
NEXT_PUBLIC_STRATEGY_EXECUTOR=
NEXT_PUBLIC_MOCK_LP_POOL=

# AI (optional — falls back to heuristics)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL + Prisma (optional for extended backend)
DATABASE_URL=postgresql://user:password@localhost:5432/treasurer?schema=public
